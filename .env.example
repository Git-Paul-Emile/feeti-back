# ═══════════════════════════════════════════════════════════════════
#  feeti2 — Backend — Variables d'environnement
#  Copier ce fichier en .env et remplir les valeurs
# ═══════════════════════════════════════════════════════════════════

# ── Application ─────────────────────────────────────────────────────
NAME_APP="Féeti"
NODE_ENV=development                 # development | production

# ── Base de données PostgreSQL ───────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/feeti2
# Exemple production : postgresql://user:pass@db.host.com:5432/feeti_prod

# ── JWT ─────────────────────────────────────────────────────────────
# Générer avec : node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
ACCESS_TOKEN_SECRET=CHANGE_ME_RANDOM_64_BYTES_BASE64
REFRESH_TOKEN_SECRET=CHANGE_ME_RANDOM_64_BYTES_BASE64
ACCESS_TOKEN_EXPIRY=1d
REFRESH_TOKEN_EXPIRY=7d

# ── Sécurité ────────────────────────────────────────────────────────
BCRYPT_SALT=10
TICKET_SECRET=CHANGE_ME_TICKET_HMAC_SECRET

# ── URLs (CORS + cross-app) ──────────────────────────────────────────
FRONT_URL=http://localhost:3000         # URL du frontend feeti2
FEETIPLAY_URL=http://localhost:5173     # URL du frontend feetiPlay
FEETIPLAY_API_URL=http://localhost:8001/api
FEETI_SYNC_SECRET=CHANGE_ME_SYNC_SECRET

# ── Email SMTP ───────────────────────────────────────────────────────
# Provider actif : nodemailer (SMTP)
# Pour passer à SendGrid : mettre EMAIL_PROVIDER=sendgrid + SENDGRID_API_KEY
EMAIL_PROVIDER=nodemailer              # nodemailer | sendgrid | resend
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre.email@gmail.com
SMTP_PASS=votre_app_password_gmail     # App password Gmail (pas le mot de passe principal)
EMAIL_FROM="Féeti <noreply@feeti.app>"

# Pour passer à SendGrid : décommenter et remplir
# EMAIL_PROVIDER=sendgrid
# SENDGRID_API_KEY=SG.XXXXXXXXXXXXXXXXXXXX

# ── Cloudinary (upload d'images) ─────────────────────────────────────
# Obtenir sur cloudinary.com > Dashboard > API Keys
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# ── Paiements (Simulation — remplacer par les vraies clés en prod) ───
# Stripe
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXX          # clé secrète Stripe (backend)
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXX        # webhook secret Stripe

# Paystack
PAYSTACK_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXX

# ── Paramètres financiers ────────────────────────────────────────────
PAYOUT_DOUBLE_VALIDATION_THRESHOLD=100000  # Montant (centimes) déclenchant double validation
